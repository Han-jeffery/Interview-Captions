PORT=3210

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-flash

# ASR provider: deepgram or iflytek
ASR_PROVIDER=deepgram

# Deepgram realtime ASR, used by many open-source interview assistant projects.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-US

# iFlytek Real-time ASR, optional fallback.
# Use the credentials from 讯飞开放平台 -> 实时语音转写.
IFLYTEK_APP_ID=
IFLYTEK_API_KEY=

# Optional tuning
QUESTION_IDLE_MS=1800
QUESTION_MIN_CHARS=18
